                <mxCell id="3" value="==========================================================================================&#10;                     FRONTEND (CLIENT SIDE) -&gt; REACT.JS&#10;==========================================================================================&#10;&#10;&#10; [ STEP 1: UI TRIGGER ]&#10; ┌────────────────────────────────────────────────────────────────────────────────┐&#10; │ CategoryNav.jsx / FilterSidebar.jsx                                            │&#10; │                                                                                │&#10; │ // Jab user bubble ya sidebar par click karta hai:                             │&#10; │ onClick={() =&gt; navigate('/products?category_slug=fruits')}                    │&#10; └───────────────────────────────────────┬────────────────────────────────────────┘&#10;                                         │ &#10;                                         ▼ (Address bar me params add hote hain)&#10; ┌────────────────────────────────────────────────────────────────────────────────┐&#10; │ BROWSER URL BAR:  http://localhost:5173/products?category_slug=fruits          │&#10; └───────────────────────────────────────┬────────────────────────────────────────┘&#10;                                         │&#10;                                         ▼ (useSearchParams URL change ko listen karta hai)&#10; [ STEP 2: STATE LISTENER ]&#10; ┌────────────────────────────────────────────────────────────────────────────────┐&#10; │ ProductGrid.jsx                                                                │&#10; │                                                                                │&#10; │ const [searchParams] = useSearchParams();                                      │&#10; │                                                                                │&#10; │ useEffect(() =&gt; {                                                              │&#10; │   GetProducts({                                                                │&#10; │     category_slug: searchParams.get(&quot;category_slug&quot;) // -&gt; &quot;fruits&quot;            │&#10; │   });                                                                          │&#10; │ }, [searchParams]); // ⚡ URL badalte hi dibba dobara chalta hai               │&#10; └───────────────────────────────────────┬────────────────────────────────────────┘&#10;                                         │&#10;                                         ▼ (Object bankar API file me jata hai)&#10; [ STEP 3: URL SERIALIZER ]&#10; ┌────────────────────────────────────────────────────────────────────────────────┐&#10; │ AllApi.js (GetProducts Function)                                               │&#10; │                                                                                │&#10; │ if (query.category_slug) {                                                     │&#10; │     filter.append(&quot;category_slug&quot;, query.category_slug);                       │&#10; │ }                                                                              │&#10; │ // Output: filter.toString() -&gt; &quot;category_slug=fruits&quot;                         │&#10; │ const response = await axiosinstance.get(`/product?${filter.toString()}`);     │&#10; └───────────────────────────────────────┬────────────────────────────────────────┘&#10;                                         │&#10;                                         │  HTTP GET Request:&#10;                                         │  /api/product?category_slug=fruits&#10;                                         ▼&#10;==========================================================================================&#10;                     BACKEND (SERVER SIDE) -&gt; NODE.JS / EXPRESS&#10;==========================================================================================&#10;&#10;&#10; [ STEP 4: CONTROLLER &amp; DATABASE QUERY ]&#10; ┌────────────────────────────────────────────────────────────────────────────────┐&#10; │ productController.js                                                           │&#10; │                                                                                │&#10; │ const getAllProducts = async (req, res) =&gt; {                                   │&#10; │     try {                                                                      │&#10; │         // Express URL se query parameters ko object me todta hai:             │&#10; │         const { category_slug } = req.query; // -&gt; &quot;fruits&quot;                    │&#10; │                                                                                │&#10; │         let filterObject = {};                                                 │&#10; │         if (category_slug) {                                                   │&#10; │             filterObject.category_slug = category_slug;                        │&#10; │         }                                                                      │&#10; │                                                                                │&#10; │         // MongoDB se filtered data laate hain:                                │&#10; │         const products = await Product.find(filterObject);                     │&#10; │                                                                                │&#10; │         res.json({ success: true, allProducts: products });                    │&#10; │     } catch(err) { ... }                                                       │&#10; │ };                                                                             │&#10; └────────────────────────────────────────────────────────────────────────────────┘" style="text;whiteSpace=wrap;html=1;" vertex="1" parent="1">
